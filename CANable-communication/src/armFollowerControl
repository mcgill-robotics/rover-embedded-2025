import time
from armCANCommunicationV2 import CANStation, ArmESCInterface, ArmNodeID

# Parameters
frequency_hz = 100  # Update frequency in Hz
step_time = 1.0 / frequency_hz
speed_dps = 10.0    # Desired speed in degrees/sec
travel_deg = 90     # Target motion in degrees

# Compute number of steps and delta per step
n_steps = int(abs(travel_deg) / (speed_dps * step_time))
step_size = speed_dps / frequency_hz
if travel_deg < 0:
    step_size *= -1

# Setup CAN interface
station = CANStation(interface="slcan", channel="COM7", bitrate=500000)
arm = ArmESCInterface(station)

# Initial position
current_position = 0.0

print(f"Starting trajectory of {travel_deg}° at {speed_dps}°/s over {n_steps} steps...")

for _ in range(n_steps):
    current_position += step_size
    arm.run_follower(ArmNodeID.SHOULDER, current_position)
    time.sleep(step_time)

print("Trajectory complete.")
station.close()
